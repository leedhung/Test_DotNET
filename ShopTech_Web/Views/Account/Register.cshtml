@model ShopTech_Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký ShopTech";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    body { background-color: #f8f9fa; }
    .auth-wrapper { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; margin-top: 2rem; margin-bottom: 2rem; }
    .brand-title { font-weight: 800; font-size: 2rem; letter-spacing: 1px; color: #212529; }
    .brand-subtitle { color: #6c757d; font-size: 0.95rem; margin-bottom: 1.5rem; }
    .auth-card { background: #ffffff; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.04); border: none; padding: 2.5rem; width: 100%; max-width: 500px; }
    
    .card-header-text { font-size: 1.5rem; font-weight: 700; color: #212529; }
    .card-sub-text { font-size: 0.85rem; color: #6c757d; margin-bottom: 2rem; }
    
    .custom-label { font-size: 0.75rem; font-weight: 700; color: #6c757d; text-transform: uppercase; letter-spacing: 0.5px; }
    
    /* Style cho input có icon bên trong và nền xám nhạt như bản thiết kế */
    .input-group-custom .input-group-text { background-color: #f1f3f5; border: none; border-radius: 8px 0 0 8px; color: #adb5bd; padding-left: 1.2rem; }
    .input-group-custom .form-control { background-color: #f1f3f5; border: none; border-radius: 0 8px 8px 0; padding: 0.85rem 1rem 0.85rem 0; font-size: 0.95rem;}
    .input-group-custom .form-control:focus { box-shadow: none; background-color: #e9ecef; }
    .input-group-custom:focus-within .input-group-text, .input-group-custom:focus-within .form-control { background-color: #e9ecef; color: #495057;}
    
    .btn-primary-custom { background-color: #0d6efd; border: none; border-radius: 8px; font-weight: 600; padding: 0.85rem; transition: all 0.3s; }
    .btn-primary-custom:hover { background-color: #0b5ed7; transform: translateY(-1px); }
    .footer-trust { font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; color: #adb5bd; text-transform: uppercase; margin-top: 3rem; }
</style>

<div class="auth-wrapper">
    <div class="text-center">
        <h1 class="brand-title">SHOPTECH</h1>
        <p class="brand-subtitle">Gia nhập bộ sưu tập tuyển chọn.</p>
    </div>

    <div class="auth-card">
        <h2 class="card-header-text">Tạo Tài Khoản</h2>
        <p class="card-sub-text">Điền thông tin của bạn để bắt đầu.</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label custom-label">HỌ VÀ TÊN</label>
                <div class="input-group input-group-custom">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên đầy đủ" />
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label custom-label">EMAIL</label>
                <div class="input-group input-group-custom">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="example@shoptech.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label custom-label">MẬT KHẨU</label>
                <div class="input-group input-group-custom">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="........" />
                    <span class="input-group-text" style="border-radius: 0 8px 8px 0; padding-right: 1.2rem;"><i class="fas fa-eye text-muted"></i></span>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label custom-label">XÁC NHẬN MẬT KHẨU</label>
                <div class="input-group input-group-custom">
                    <span class="input-group-text"><i class="fas fa-shield-check"></i></span>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="........" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check d-flex align-items-center">
                <input class="form-check-input me-2" type="checkbox" id="termsAgree" required>
                <label class="form-check-label small text-muted" for="termsAgree">
                    Tôi đồng ý với <a href="#" class="text-decoration-none fw-bold text-primary">Điều khoản dịch vụ</a> và <a href="#" class="text-decoration-none fw-bold text-primary">Chính sách bảo mật</a>.
                </label>
            </div>

            <button type="submit" class="btn btn-primary-custom w-100 text-white mb-3">Đăng Ký</button>
            
            <div class="text-center small">
                <span class="text-muted">Đã có tài khoản?</span> 
                <a asp-action="Login" class="text-decoration-none fw-bold text-primary">Đăng nhập tại đây</a>
            </div>
        </form>
    </div>
    
    <div class="footer-trust">
        TRUSTED GLOBALLY BY TECH LEADERS
    </div>
</div>