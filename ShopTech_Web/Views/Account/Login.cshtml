@model ShopTech_Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập ShopTech";
}

<style>
    /* CSS Tùy chỉnh tái tạo giao diện KINETIC */
    body { background-color: #f8f9fa; }
    .auth-wrapper { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; }
    .brand-title { font-weight: 800; font-size: 2rem; letter-spacing: 1px; color: #212529; }
    .brand-subtitle { color: #6c757d; font-size: 0.95rem; margin-bottom: 2rem; }
    .auth-card { background: #ffffff; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.04); border: none; padding: 2.5rem; width: 100%; max-width: 450px; }
    .custom-label { font-size: 0.75rem; font-weight: 700; color: #6c757d; text-transform: uppercase; letter-spacing: 0.5px; }
    .custom-input { border-radius: 8px; padding: 0.75rem 1rem; border: 1px solid #e9ecef; }
    .custom-input:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.25rem rgba(13,110,253,.15); }
    .btn-primary-custom { background-color: #0d6efd; border: none; border-radius: 8px; font-weight: 600; padding: 0.75rem; transition: all 0.3s; }
    .btn-primary-custom:hover { background-color: #0b5ed7; transform: translateY(-1px); }
</style>

<div class="auth-wrapper">
    <div class="text-center">
        <h1 class="brand-title">SHOPTECH</h1>
        <p class="brand-subtitle">Đăng nhập vào bộ sưu tập công nghệ của bạn</p>
    </div>

    <div class="auth-card">
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label custom-label">ĐỊA CHỈ EMAIL</label>
                <input asp-for="Email" class="form-control custom-input" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label asp-for="Password" class="form-label custom-label mb-0">MẬT KHẨU</label>
                    <a href="#" class="text-decoration-none small fw-bold text-primary">Quên mật khẩu?</a>
                </div>
                <input asp-for="Password" class="form-control custom-input" placeholder="........" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" id="rememberMe">
                <label class="form-check-label small text-muted" for="rememberMe">
                    Ghi nhớ đăng nhập
                </label>
            </div>

            <button type="submit" class="btn btn-primary-custom w-100 text-white">Đăng Nhập</button>
        </form>
    </div>

    <div class="mt-4 text-center small">
        <span class="text-muted">Chưa có tài khoản?</span> 
        <a asp-action="Register" class="text-decoration-none fw-bold text-primary">Đăng ký</a>
    </div>
</div>