@model ShopTech_Web.ViewModels.LoginViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center mb-4">Đăng Nhập</h2>
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn..." />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu..." />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Nhớ mật khẩu</label>
                </div>

                <button type="submit" class="btn btn-success w-100">Đăng Nhập</button>
            </form>
            <div class="mt-3 text-center">
                <a asp-action="Register" class="text-decoration-none">Chưa có tài khoản? Đăng ký ngay</a>
            </div>
        </div>
    </div>
</div>